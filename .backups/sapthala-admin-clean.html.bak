        const MEASUREMENT_LABELS = {
            'BL': 'Blouse Length', 'B': 'Bust', 'W': 'Waist', 'SH': 'Shoulder',
            'LL': 'Lehenga Length', 'LW': 'Lehenga Waist', 'FL': 'Frock Length',
