                <div style="display: flex; gap: 10px; margin-top: 20px;">
                    <button type="submit" class="btn-primary" style="flex: 1;">✅ Save Staff</button>
                    <button type="button" class="btn-secondary" onclick="closeStaffModal()" style="flex: 1;">Cancel</button>
