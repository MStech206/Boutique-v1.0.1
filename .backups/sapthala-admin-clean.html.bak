    </div> <!-- End Main App -->

    <!-- Staff Modal -->
    <div id="staffModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2 id="staffModalTitle">➕ Add New Staff</h2>
                <button class="modal-close" onclick="closeStaffModal()">×</button>
            </div>
            <form id="staffForm" onsubmit="saveStaff(event)">
                <input type="hidden" id="staffEditId">
                <div class="form-group">
                    <label>Full Name *</label>
                    <input type="text" id="staffName" placeholder="Enter staff name" required>
                </div>
                <div class="form-group">
                    <label>Phone Number *</label>
                    <input type="tel" id="staffPhone" placeholder="Enter phone number" required>
                </div>
                <div class="form-group">
                    <label>Email</label>
                    <input type="email" id="staffEmail" placeholder="Enter email (optional)">
                </div>
                <div class="form-group">
                    <label>Role/Designation *</label>
                    <input type="text" id="staffRole" placeholder="e.g., Dyeing Specialist" required>
                </div>
                <div class="form-group">
                    <label>Staff ID (Username) *</label>
                    <input type="text" id="staffUsername" placeholder="e.g., staff_010" required>
                </div>
                <div class="form-group">
                    <label>PIN/Password (4 digits) *</label>
                    <input type="text" id="staffPin" placeholder="Enter 4-digit PIN" maxlength="4" pattern="[0-9]{4}" required>
                </div>
                <div class="form-group">
                    <label>Branch *</label>
                    <select id="staffBranch" required style="padding:10px;border-radius:8px;border:1px solid #cbd5e1;background:white;font-weight:600;">
                        <option value="">Select branch</option>
                    </select>
                    <datalist id="branchesDatalist" style="display:none"></datalist>
                </div>
