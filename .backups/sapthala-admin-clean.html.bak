                            <span>🎨 Dyeing</span>
                        </label>
                        <label class="checkbox-label">
                            <input type="checkbox" name="stages" value="cutting">
                            <span>✂️ Cutting</span>
                        </label>
                        <label class="checkbox-label">
                            <input type="checkbox" name="stages" value="stitching">
                            <span>🧵 Stitching</span>
                        </label>
                        <label class="checkbox-label">
                            <input type="checkbox" name="stages" value="khakha">
                            <span>🔗 Khakha</span>
                        </label>
                        <label class="checkbox-label">
                            <input type="checkbox" name="stages" value="maggam">
                            <span>✨ Maggam</span>
                        </label>
                        <label class="checkbox-label">
                            <input type="checkbox" name="stages" value="painting">
                            <span>🎭 Painting</span>
                        </label>
