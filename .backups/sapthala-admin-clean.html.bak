    <!-- Sub-Admin Modal -->
    <div id="subAdminModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2 id="subAdminModalTitle">➕ Add Sub-Admin</h2>
                <button class="modal-close" onclick="closeSubAdminModal()">×</button>
            </div>
            <form id="subAdminForm" onsubmit="saveSubAdmin(event)">
                <input type="hidden" id="subAdminEditId">
                <div class="form-group">
                    <label>Username *</label>
                    <input type="text" id="subAdminUsername" placeholder="e.g., jubilee_admin" required>
                </div>
                <div class="form-group">
                    <label>Password *</label>
                    <input type="password" id="subAdminPassword" placeholder="Enter secure password" required>
                </div>
                <div class="form-group">
                    <label>Branch Name *</label>
                    <input type="text" id="subAdminBranch" list="branchesDatalist" placeholder="Start typing branch name or select..." required>
                    <datalist id="branchesDatalist"></datalist>
                </div>
                <div class="form-group">
                    <label>Permissions</label>
