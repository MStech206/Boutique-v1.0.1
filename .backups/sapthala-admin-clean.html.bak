        let currentTheme = 'default';

        // Festival dates (month, day) - adjust as needed. Used to find nearest festival.
        // This object can be overridden via admin settings (loaded from localStorage)
        let FESTIVAL_DATES = {
            independence: { month: 8, day: 15 },
            ugadi: { month: 4, day: 9 },
            holi: { month: 3, day: 25 },
            diwali: { month: 11, day: 4 },
            sankranti: { month: 1, day: 14 },
            ganesh: { month: 9, day: 10 },
            newYear: { month: 1, day: 1 },
            ramadan: { month: 4, day: 10 },
            christmas: { month: 12, day: 25 }
        };

        function loadFestivalSettings() {
            try {
                // Prefer server-side persisted festival settings when authenticated
                const token = localStorage.getItem('sapthala_token') || sessionStorage.getItem('sapthala_token');
                if (token) {
                    try {
                        fetch('/api/festivals', { headers: { 'Authorization': `Bearer ${token}` } })
                            .then(r => r.json())
                            .then(data => {
                                if (data && data.success && data.festivals) {
                                    Object.keys(data.festivals).forEach(k => {
                                        const v = data.festivals[k];
                                        if (v && v.month && v.day) FESTIVAL_DATES[k] = { month: v.month, day: v.day };
                                    });
                                }
                            }).catch(e => console.warn('Failed to load festivals from server:', e));
                    } catch (e) {
                        console.warn('Server fetch error for festivals:', e);
                    }
                }

                // Local override fallback
                const raw = localStorage.getItem('sapthala_festivals');
                if (!raw) return;
                const parsed = JSON.parse(raw);
                if (parsed && typeof parsed === 'object') {
                    Object.keys(parsed).forEach(k => {
                        if (parsed[k] && parsed[k].month && parsed[k].day) FESTIVAL_DATES[k] = { month: parsed[k].month, day: parsed[k].day };
                    });
                }
            } catch (e) {
                console.warn('Failed to load festival settings', e);
            }
        }

        function getNextOccurrence(month, day) {
            const now = new Date();
            let year = now.getFullYear();
            let d = new Date(year, month - 1, day);
            if (d < now) d = new Date(year + 1, month - 1, day);
            // normalize to midnight
            d.setHours(0,0,0,0);
            return d;
        }

        function daysUntil(date) {
            const now = new Date();
            const ms = date - now;
            return Math.ceil(ms / (1000 * 60 * 60 * 24));
        }

        function autoActivateNearestFestival() {
            try {
                const autoPref = localStorage.getItem('sapthala_auto_theme');
                if (autoPref === 'false') return; // user opted out

                let nearest = null;
                let minDays = Infinity;
                Object.keys(FESTIVAL_DATES).forEach(key => {
                    const { month, day } = FESTIVAL_DATES[key];
                    const nxt = getNextOccurrence(month, day);
                    const delta = daysUntil(nxt);
                    if (delta < minDays) { minDays = delta; nearest = key; }
                });

                if (!nearest) return;

                // mark upcoming on UI
                document.querySelectorAll('.theme-card .badge-upcoming').forEach(b => b.remove());
                const nearestCard = document.querySelector(`[data-theme="${nearest}"]`);
                if (nearestCard) {
                    const badge = document.createElement('div');
                    badge.className = 'badge-upcoming';
                    badge.textContent = 'Upcoming';
                    nearestCard.appendChild(badge);
                }

                // Auto-apply for main admins only when user hasn't explicitly chosen a theme
                const savedTheme = localStorage.getItem('sapthala_current_theme');
                const userStr = localStorage.getItem('sapthala_user') || sessionStorage.getItem('sapthala_user');
                let isSub = false;
                try { const u = userStr ? JSON.parse(userStr) : null; if (u && u.role === 'sub-admin') isSub = true; } catch(e){}

                if (!isSub && (!savedTheme || savedTheme === 'default')) {
                    applyTheme(nearest);
                    showThemeNotification(`Auto theme activated: ${THEMES[nearest].name}`);
                }
            } catch (e) {
                console.warn('autoActivateNearestFestival error', e);
            }
        }

        // Save festival settings from UI
        function saveFestivalSettings() {
            try {
                const ugadi = document.getElementById('ugadiDate').value.trim();
                const diwali = document.getElementById('diwaliDate').value.trim();
                const independence = document.getElementById('independenceDate').value.trim();
                const obj = {};
                if (ugadi) {
                    const [m,d] = ugadi.split('-').map(Number);
                    if (!isNaN(m) && !isNaN(d)) obj['ugadi'] = { month: m, day: d };
                }
                if (diwali) {
                    const [m,d] = diwali.split('-').map(Number);
                    if (!isNaN(m) && !isNaN(d)) obj['diwali'] = { month: m, day: d };
                }
                if (independence) {
                    const [m,d] = independence.split('-').map(Number);
                    if (!isNaN(m) && !isNaN(d)) obj['independence'] = { month: m, day: d };
                }
                // Try to persist to server when logged in as admin
                const token = localStorage.getItem('sapthala_token') || sessionStorage.getItem('sapthala_token');
                if (token) {
                    fetch('/api/admin/festivals', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                        body: JSON.stringify(obj)
                    }).then(r => r.json()).then(data => {
                        if (data && data.success) {
                            localStorage.removeItem('sapthala_festivals');
                            loadFestivalSettings();
                            alert('✅ Festival dates saved to server');
                        } else {
                            // fallback to local storage
                            localStorage.setItem('sapthala_festivals', JSON.stringify(obj));
                            loadFestivalSettings();
                            alert('⚠️ Saved locally (server refused): ' + (data && data.error ? data.error : 'Unknown'));
                        }
                    }).catch(e => {
                        console.warn('Save festivals to server failed:', e);
                        localStorage.setItem('sapthala_festivals', JSON.stringify(obj));
                        loadFestivalSettings();
                        alert('⚠️ Saved locally (server error)');
                    });
                } else {
                    // Not logged in - save locally
                    localStorage.setItem('sapthala_festivals', JSON.stringify(obj));
                    // apply immediately
                    loadFestivalSettings();
                    alert('✅ Festival dates saved locally');
                }
            } catch (e) {
                console.error('Failed to save festival settings', e);
                alert('❌ Failed to save festival dates');
            }
        }

        function initFestivalSettingsUI() {
            try {
                // If logged in, try to load from server
                const token = localStorage.getItem('sapthala_token') || sessionStorage.getItem('sapthala_token');
                if (token) {
                    try {
                        fetch('/api/festivals', { headers: { 'Authorization': `Bearer ${token}` } })
                            .then(r => r.json())
                            .then(data => {
                                if (data && data.success && data.festivals) {
                                    const parsed = data.festivals;
                                    if (parsed.ugadi) document.getElementById('ugadiDate').value = `${parsed.ugadi.month}-${parsed.ugadi.day}`;
                                    if (parsed.diwali) document.getElementById('diwaliDate').value = `${parsed.diwali.month}-${parsed.diwali.day}`;
                                    if (parsed.independence) document.getElementById('independenceDate').value = `${parsed.independence.month}-${parsed.independence.day}`;
                                }
                            }).catch(e => console.warn('Failed to fetch festival settings from server:', e));
                    } catch (e) {
                        console.warn('Error fetching festivals from server:', e);
                    }
                } else {
                    const raw = localStorage.getItem('sapthala_festivals');
                    if (raw) {
                        const parsed = JSON.parse(raw);
                        if (parsed.ugadi) document.getElementById('ugadiDate').value = `${parsed.ugadi.month}-${parsed.ugadi.day}`;
                        if (parsed.diwali) document.getElementById('diwaliDate').value = `${parsed.diwali.month}-${parsed.diwali.day}`;
                        if (parsed.independence) document.getElementById('independenceDate').value = `${parsed.independence.month}-${parsed.independence.day}`;
                    }
                }

                const autoPref = localStorage.getItem('sapthala_auto_theme');
                const autoThemeToggleEl = document.getElementById('autoThemeToggle');
                if (autoThemeToggleEl) autoThemeToggleEl.checked = (autoPref !== 'false');

                safeAddListener('saveFestivalBtn', 'click', function(e) {
                    e.preventDefault();
                    saveFestivalSettings();
                });

                safeAddListener('autoThemeToggle', 'change', function() {
                    const v = this.checked ? 'true' : 'false';
                    localStorage.setItem('sapthala_auto_theme', v);
                });
            } catch (e) {
                console.warn('initFestivalSettingsUI error', e);
            }
        }
        
