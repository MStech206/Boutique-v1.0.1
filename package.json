{
  "name": "sapthala-firebase-backend",
  "version": "1.0.0",
  "description": "Complete Firebase backend for Sapthala Boutique",
  "main": "firebase-backend-server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate": "node migrate-to-firebase.js",
    "migrate:firestore": "node scripts/migrate_mongo_to_firestore.js --collections=branches,staff,orders,users",
    "decode:firebase-b64": "node scripts/decode_firebase_b64.js",
    "sync-firebase": "node sync-to-firebase.js",
    "test": "node test-firebase-connection.js",
    "test:unit": "node scripts/unit-test-notification-service.js && node scripts/unit-test-firestore-health.js",
    "test:ui-pricing": "node scripts/ui-pricing-regression.js",
    "test:e2e-dashboard-fallback": "node scripts/e2e-dashboard-firestore-fallback.js",
    "test:reports-consistency": "node scripts/test-reports-firestore-consistency.js",
    "test:charts": "node scripts/test-dashboard-charts.js",
    "test:validate-order": "node scripts/test-validate-order.js",
    "test:e2e-dataflow": "node scripts/e2e-with-staff.js"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "express": "^4.18.2",
    "firebase-admin": "^12.7.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^6.3.0",
    "mongoose": "^9.2.1",
    "puppeteer": "^24.37.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "keywords": [
    "firebase",
    "backend",
    "boutique",
    "admin",
    "staff"
  ],
  "author": "Sapthala Boutique",
  "license": "MIT"
}
